# EditorConfig — 跨編輯器統一基本格式，避免無謂的 diff
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # Markdown 行尾兩個空白代表換行

[Makefile]
indent_style = tab
