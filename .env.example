# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# ASR：dev 用 mock；整合測試改 dgx 並填 endpoint
ASR_BACKEND=mock
ASR_ENDPOINT=
# 短期記憶
MEMORY_MAX_TURNS=200
TIMEZONE=Asia/Taipei
# 長期記憶（Mem0 embedder 模型）
EMBEDDING_MODEL=gemini-embedding-001
# 排程引擎
CONSOLIDATION_HOUR=3
SCHEDULER_TICK_SECONDS=60
# 主動關懷
GREETING_HOUR=8
INACTIVITY_HOUR=10
INACTIVITY_DAYS=2
# 帳號綁定
INVITE_TTL_HOURS=24
INVITE_MAX_ATTEMPTS=5
# 雲端記憶層（Supabase Postgres / pgvector；Mem0 v1.1 新演算法）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
LONGTERM_TOP_K=5
# 帳號綁定流程（引導式對話會話逾時，分鐘）
BINDING_SESSION_TTL_MINUTES=10
# 用藥提醒（時段鐘點）
MEDICATION_MORNING_HOUR=8
MEDICATION_NOON_HOUR=12
MEDICATION_EVENING_HOUR=18
MEDICATION_BEDTIME_HOUR=21
