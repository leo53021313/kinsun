# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# ASR：dev 用 mock；接 DGX 真模型改 dgx 並填 endpoint
ASR_BACKEND=mock
ASR_ENDPOINT=
# TTS：dev/demo 用 bubble（文字泡泡）；接 DGX 真模型改 dgx 並填 endpoint
TTS_BACKEND=bubble
TTS_ENDPOINT=
TTS_TIMEOUT_SECONDS=30
# 語音回覆形式：true＝語音＋文字；false＝只語音
TTS_REPLY_TEXT=true
# 短期記憶
MEMORY_MAX_TURNS=200
TIMEZONE=Asia/Taipei
# 長期記憶（Mem0 embedder 模型）
EMBEDDING_MODEL=gemini-embedding-001
# 排程引擎
CONSOLIDATION_HOUR=3
SCHEDULER_TICK_SECONDS=60
# 主動關懷
GREETING_HOUR=8
INACTIVITY_HOUR=10
INACTIVITY_DAYS=2
# 帳號綁定
INVITE_TTL_HOURS=24
INVITE_MAX_ATTEMPTS=5
# 雲端記憶層（Supabase Postgres / pgvector）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
LONGTERM_TOP_K=5
# 語音回覆音檔託管（Supabase Storage；TTS_BACKEND=dgx 時必填）
# service_role 金鑰：後台 Settings→API（非 DB 密碼）；需先建同名 Public bucket
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=
AUDIO_BUCKET=tts-audio
AUDIO_RETENTION_DAYS=2
AUDIO_UPLOAD_TIMEOUT_SECONDS=10
# 帳號綁定流程（會話逾時，分鐘）
BINDING_SESSION_TTL_MINUTES=10
# 綁定閘門：false＝未綁定也可對話（僅 demo／開發，正式務必 true）
BINDING_GATE_ENABLED=true
# 用藥提醒（時段鐘點）
MEDICATION_MORNING_HOUR=8
MEDICATION_NOON_HOUR=12
MEDICATION_EVENING_HOUR=18
MEDICATION_BEDTIME_HOUR=21
# 回診提醒（鐘點）
APPOINTMENT_REMINDER_HOUR=8
# 家屬端 LIFF（LINE Login channel）
LIFF_CHANNEL_ID=
LIFF_TIMEOUT_SECONDS=10
# 家屬圖文選單（Rich Menu）
LIFF_ID=
RICH_MENU_ID=
# 佈署用（app 不讀取，供 ngrok／啟動腳本）：authtoken 機密只放 .env，網域到 ngrok Domains 取得
NGROK_AUTHTOKEN=
NGROK_DOMAIN=xxxx-xxxx.ngrok-free.app
