# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# ASR：dev 用 mock；整合測試改 dgx 並填 endpoint
ASR_BACKEND=mock
ASR_ENDPOINT=
# 短期記憶
MEMORY_MAX_TURNS=200
TIMEZONE=Asia/Taipei
# 長期記憶（Mem0 embedder 模型）
EMBEDDING_MODEL=gemini-embedding-001
# 排程引擎
CONSOLIDATION_HOUR=3
SCHEDULER_TICK_SECONDS=60
# 主動關懷
GREETING_HOUR=8
INACTIVITY_HOUR=10
INACTIVITY_DAYS=2
# 帳號綁定
INVITE_TTL_HOURS=24
INVITE_MAX_ATTEMPTS=5
# 雲端記憶層（Supabase Postgres / pgvector + Neo4j Aura）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
LONGTERM_TOP_K=5
