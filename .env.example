# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
# ASR：dev 用 mock；整合測試改 dgx 並填 endpoint（DGX 上 services/asr 服務位址）
ASR_BACKEND=mock
ASR_ENDPOINT=
# TTS：dev/demo 用 bubble（文字泡泡，不產音檔）；接 DGX 真模型改 dgx 並填 endpoint
TTS_BACKEND=bubble
TTS_ENDPOINT=
TTS_TIMEOUT_SECONDS=30
# 語音回覆形式：true＝語音＋文字泡泡；false＝只發語音
TTS_REPLY_TEXT=true
# 短期記憶
MEMORY_MAX_TURNS=200
TIMEZONE=Asia/Taipei
# 長期記憶（Mem0 embedder 模型）
EMBEDDING_MODEL=gemini-embedding-001
# 排程引擎
CONSOLIDATION_HOUR=3
SCHEDULER_TICK_SECONDS=60
# 主動關懷
GREETING_HOUR=8
INACTIVITY_HOUR=10
INACTIVITY_DAYS=2
# 帳號綁定
INVITE_TTL_HOURS=24
INVITE_MAX_ATTEMPTS=5
# 雲端記憶層（Supabase Postgres / pgvector；Mem0 v1.1 新演算法）
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
LONGTERM_TOP_K=5
# 語音回覆音檔託管（Supabase Storage 公開 bucket；TTS_BACKEND=dgx 時必填 URL 與 service_role 金鑰）
# ⚠ SUPABASE_SERVICE_KEY 是 Storage REST API 的 JWT（後台 Settings→API→service_role），
#   與 DATABASE_URL 的資料庫密碼是不同憑證、不同服務，不能互相取代。
# ⚠ 需先在 Supabase 後台建立一個「Public」bucket，名稱同 AUDIO_BUCKET。
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=
AUDIO_BUCKET=tts-audio
# 音檔保留天數（每日清理 job 刪除超過天數的日期資料夾）
AUDIO_RETENTION_DAYS=2
AUDIO_UPLOAD_TIMEOUT_SECONDS=10
# 帳號綁定流程（引導式對話會話逾時，分鐘）
BINDING_SESSION_TTL_MINUTES=10
# 綁定閘門：false 時未綁定也可直接對話（僅供 demo／開發，正式環境務必 true）
BINDING_GATE_ENABLED=true
# 用藥提醒（時段鐘點）
MEDICATION_MORNING_HOUR=8
MEDICATION_NOON_HOUR=12
MEDICATION_EVENING_HOUR=18
MEDICATION_BEDTIME_HOUR=21
# 回診提醒（前一天與當天早上提醒的鐘點）
APPOINTMENT_REMINDER_HOUR=8
# 家屬端 LIFF（LINE Login channel 與 Messaging API 同 provider）
LIFF_CHANNEL_ID=
LIFF_TIMEOUT_SECONDS=10
# 家屬圖文選單（Rich Menu）：LIFF_ID 佈建用、RICH_MENU_ID 綁定時 link 用
LIFF_ID=
RICH_MENU_ID=
